{
  "name": "betterlaspinas",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.29.2",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "test:e2e": "npx playwright test && npx playwright show-report",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:chromium": "npx playwright test --project chromium",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:codegen": "npx playwright codegen",
    "test:e2e:file": "npx playwright test tests/api.spec.ts",
    "test:e2e:sanity": "npx playwright test --grep @test_value",
    "test:e2e:local": "BASE_URL=http://localhost:4200 npx playwright test",
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "typecheck": "nuxi typecheck",
    "prepare": "husky"
  },
  "dependencies": {
    "@pinia/nuxt": "^0.11.3",
    "@types/leaflet": "^1.9.21",
    "@vue-leaflet/vue-leaflet": "^0.10.1",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "fuse.js": "^7.1.0",
    "leaflet": "^1.9.4",
    "lucide-vue-next": "^0.577.0",
    "nuxt": "^4.4.2",
    "pinia": "^3.0.4",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "vue": "^3.5.31",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@nuxt/test-utils": "^4.0.0",
    "@nuxtjs/seo": "^4.0.2",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.27",
    "commander": "^13.1.0",
    "eslint": "^10.1.0",
    "eslint-plugin-format": "^2.0.1",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6"
  }
}
